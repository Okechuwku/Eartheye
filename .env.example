# Core application settings
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost/eartheye
JWT_SECRET=replace_with_a_long_random_secret
API_URL=https://api.eartheye.me
SCAN_STORAGE_PATH=/var/lib/eartheye/scans

# Optional production settings
DEFAULT_ADMIN_EMAIL=admin@eartheye.me
DEFAULT_ADMIN_PASSWORD=change_this_before_deploy
CORS_ORIGINS=https://www.eartheye.me,https://eartheye.me
ALLOWED_HOSTS=www.eartheye.me,eartheye.me,localhost,127.0.0.1
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_GLOBAL_REQUESTS=240
RATE_LIMIT_AUTH_REQUESTS=20
RATE_LIMIT_SCAN_CREATE_REQUESTS=10
ALLOW_PRIVATE_SCAN_TARGETS=false
MAX_AUTOMATION_DOMAINS=50
